{
  "version": 2,
  "installCommand": "npm install --prefix legacy_html",
  "builds": [
    {
      "src": "legacy_html/server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "legacy_html/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "legacy_html/server.js"
    }
  ]
}
